{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "baseUrl": ".",
    "module": "esnext",
    "paths": {
      "@/*": [
        "./*"
      ],
      "@/lib/*": [
        "./lib/*"
      ],
      "@/src/*": [
        "./src/*"
      ]
    },
    "types": [
      "jest"
    ],
    "typeRoots": [
      "./types",
      "./node_modules/@types"
    ],
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": true,
    "jsx": "react-native",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "app",
    "src",
    "lib",
    "hooks",
    "services",
    "utils",
    "config",
    "scripts",
    "__tests__",
    "types",
    ".expo/types/**/*.ts",
    "expo-env.d.ts"
  ]
}
