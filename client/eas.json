{
  "cli": {
    "version": ">= 16.27.0",
    "appVersionSource": "local",
    "promptToConfigurePushNotifications": true
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      }
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      }
    },
    "production": {
      "autoIncrement": true,
      "ios": {
        "image": "latest"
      },
      "android": {
        "buildType": "app-bundle",
        "resourceClass": "large"
      }
    },
    "production-apk": {
      "autoIncrement": true,
      "android": {
        "buildType": "apk",
        "resourceClass": "large"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "ascAppId": "6760894554"
      }
    }
  }
}